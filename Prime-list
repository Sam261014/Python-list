n = int(input("Enter the number of elements: "))
numbers = [0] * n
for i in range(n):
    numbers[i] = int(input("Enter number: "))
for i in range(n):
    count = 0
    for j in range(1, numbers[i] + 1):
        if numbers[i] % j == 0:
            count = count + 1
    if count == 2:
        print(numbers[i], "is a Prime Number")
    else:
        print(numbers[i], "is Not a Prime Number")
